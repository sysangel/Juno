# Copy this file to .env and fill in your values:  cp .env.example .env
#
# PROVIDER selects which backend get_llm() builds.
#   openrouter (default) -> needs OPENROUTER_API_KEY
#   bedrock              -> needs AWS creds + region (see commented block below)

PROVIDER=openrouter

# --- OpenRouter (OpenAI-compatible) -----------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The two-model team defaults in agent_loop.py are deepseek/deepseek-v4-pro for
# both write_code and write_tests/critique. Use --model to pin BOTH roles to one
# slug (solo mode, disables critique), or --code-model / --test-model to assign
# per-role. MODEL env is supported for legacy solo mode but is NOT required.
# MODEL=deepseek/deepseek-v4-pro

# --- Custom CLI harness -----------------------------------------------------
# harness.py can talk to OpenRouter, OpenAI/ChatGPT, or Anthropic first-party
# APIs. It stores its own memory/transcripts under ~/.agent-harness by default.
# Examples:
#   .venv/Scripts/python.exe harness.py --provider openrouter -q "hello"
#   .venv/Scripts/python.exe harness.py --provider openai --model gpt-5.1
#   .venv/Scripts/python.exe harness.py --provider anthropic --model claude-sonnet-4-20250514
#   .venv/Scripts/python.exe harness.py --provider claude-code --model sonnet -q "hello"
#
# HARNESS_PROVIDER=openrouter
# HARNESS_UI=auto              # interactive UI: auto (Juno on a real console,
#                              # else plain), plain, or prompt (force Juno)
#
# Model catalog shortcuts used by /model in Juno. Override these if your exact
# OpenRouter/Fusion panel slugs differ.
# HARNESS_DP_MODEL=deepseek/deepseek-v4-pro
# HARNESS_FM3V4_MODEL=deepseek/deepseek-v4-pro
# HARNESS_FBUDGET_MODEL=openrouter/auto
# HARNESS_FHIGH_MODEL=openrouter/auto
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_MODEL=gpt-5.1
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# CLAUDE_CODE_MODEL=sonnet
# AGENT_HARNESS_HOME=C:/Users/Core/.agent-harness

# --- AWS Bedrock (optional) -------------------------------------------------
# Uncomment and set PROVIDER=bedrock to use ChatBedrockConverse instead.
# Region must match the model id's geo prefix (a "us." id needs a us-* region).
# Most 2026 Bedrock models are on-demand ONLY via a cross-region inference
# profile, so pass the geo-prefixed id (e.g. us.deepseek.r1-v1:0), not the bare id.
#
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.deepseek.r1-v1:0
#
# Credentials come from boto3's standard chain. Set ONE of:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
#   ...or use a named profile instead:
# AWS_PROFILE=default
